# Agente de Hospedagem Inteligente
# Variaveis de ambiente para deploy

# Geral
PORT=8000
PYTHONIOENCODING=utf-8

# URL base da API (preencher apos deploy)
API_URL=http://localhost:8000

# WhatsApp (Evolution API)
WHATSAPP_API_KEY=sua_chave_aqui
WHATSAPP_INSTANCE=instancia_1
WHATSAPP_BASE_URL=https://api.evolution-api.com
WHATSAPP_WEBHOOK_SECRET=seu_webhook_secret

# Instagram (via Whatsapp Cloud API ou automation)
INSTAGRAM_ACCESS_TOKEN=seu_token
INSTAGRAM_BUSINESS_ID=seu_business_id

# Airbnb iCal - URLs dos calendarios
ICAL_FAROL_BARRA=https://www.airbnb.com.br/calendar/ical/41662018.ics
